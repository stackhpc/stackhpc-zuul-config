zuul_operator_tenant_config:
  - authorization-rule:
      name: stackhpc_admin
      conditions:
        - zuul_uid: "alex@stackhpc.com"
        - zuul_uid: "bartosz@stackhpc.com"
        - zuul_uid: "jack@stackhpc.com"
        # Michal Nasiadka
        - zuul_uid: "109068399179727592063"
        - zuul_uid: "piotr@stackhpc.com"
        
  - tenant:
      name: stackhpc
      admin-rules:
        - stackhpc_admin
      exclude-unprotected-branches: true
      source:
        stackhpc:
          config-projects:
            - stackhpc-zuul-config
        github:
          untrusted-projects:
            - stackhpc/ansible-collection-cephadm
            - stackhpc/stackhpc-kayobe-config:
                include-branches: &skc_downstream_branches
                  - stackhpc/2025.1
                  - stackhpc/2024.1
            - stackhpc/neutron: &neutron_downstream_branches
                include-branches:
                  - stackhpc/2025.1
        github-git:
          untrusted-projects:
            # Additional project deps from github.com
            - include: []
              projects:
              - novnc/novnc
              - sqlalchemy/alembic
              - sqlalchemy/sqlalchemy
              - svinota/pyroute2
        opendev:
          untrusted-projects:
            - opendev/base-jobs:
                shadow:
                  - stackhpc-zuul-config
                include:
                  - job
            - zuul/zuul-jobs:
                shadow:
                  - stackhpc-zuul-config
                include:
                  - job
            - include:
                - job
                - nodeset
                - project-template
              projects:
                - opendev/grafyaml
                - openstack/project-config
                - openstack/devstack
                - openstack/grenade
                - openstack/horizon:
                    include-branches: &upstream_branches
