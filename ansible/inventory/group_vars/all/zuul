---
zuul_operator_crd_url: "https://raw.githubusercontent.com/stackhpc/zuul-operator/refs/heads/stackhpc/deploy/crds/zuul-ci_v1alpha2_zuul_crd.yaml"
zuul_operator_cr: |
  apiVersion: operator.zuul-ci.org/v1alpha2
  kind: Zuul
  metadata:
    name: stackhpc-zuul
  spec:
    auth:
      google_auth:
        default: true
        driver: OpenIDConnect
        realm: stackhpc
        issuer_id: "https://accounts.google.com"
        client_id: "161754685259-nvqgt0hruifde3415k3c7r42sob7cof0.apps.googleusercontent.com"
        uid_claim: email
        scope: "openid profile email"
    connections:
      github:
        driver: github
        secretName: zuul-github
        server: github.com
      github-git:
        driver: git
        baseurl: https://github.com
      opendev:
        driver: git
        baseurl: https://opendev.org
      stackhpc:
        driver: git
        baseurl: https://github.com/stackhpc
        canonical_hostname: github.stackhpc.com
    executor:
      count: 6
      disk_limit_per_job: 5000
      storageClassName: ssd
      sshkey:
        secretName: zuul-sshkey
    externalConfig:
      openstack:
        secretName: zuul-clouds-yaml
    fingergw:
      count: 2
    merger:
      count: 6
      git_http_low_speed_time: 360
      git_timeout: 600
    scheduler:
      count: 2
      config:
        secretName: zuul-tenant-config
    launcher:
      type: both
      config:
        secretName: zuul-nodepool-config
    web:
      count: 3
      root: "https://zuul.stackhpc.com"
    zuulImageVersion: "14.2.0"
